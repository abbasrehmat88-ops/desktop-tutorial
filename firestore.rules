rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isFamily() {
      return request.auth != null
        && request.auth.token.email in [
          'abbasrehmat88@gmail.com',
          'rehmat.ae@gmail.com'
        ];
    }
    // Family-only access to every collection (tenants, owners,
    // fewaBills, reminders, properties, and anything added later).
    match /{collection}/{document=**} { allow read, write: if isFamily(); }
  }
}
